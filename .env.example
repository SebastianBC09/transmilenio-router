# =============================================================================
# Transmilenio Router - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored and should never be committed.
# Direct mode (python main.py origin destination) works without any credentials.
# NLP mode (python main.py --nlp "...") requires LLM_API_KEY to be set.
# =============================================================================


# --- LLM Provider ------------------------------------------------------------

# Which LLM provider to use for natural language query parsing and explanation.
#
# Supported values:
#   groq    - recommended, 14,400 req/day free, no credit card required
#             https://console.groq.com/keys
#   mistral - 1 billion tokens/month free
#             https://console.mistral.ai/api-keys
#   openai  - paid, most capable
#             https://platform.openai.com/api-keys
#
# Default: groq
LLM_PROVIDER=groq


# API key for the provider selected above.
# Leave blank if you are only using direct mode (no --nlp flag).
LLM_API_KEY=


# Model identifier for the provider selected above.
#
# Recommended models per provider:
#   groq    -> llama-3.3-70b-versatile   (fast, free)
#   mistral -> mistral-small-latest       (balanced, free tier)
#   openai  -> gpt-4o-mini                (cost-efficient)
#
# Full model lists:
#   Groq:    https://console.groq.com/docs/models
#   Mistral: https://docs.mistral.ai/getting-started/models
#   OpenAI:  https://platform.openai.com/docs/models
LLM_MODEL=llama-3.3-70b-versatile# =============================================================================
